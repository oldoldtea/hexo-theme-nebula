<div class="blog-header">
  <a id="menu-nav-icon"><img src="<%= config.root %>image/menu.png"/></a>

  <div class="nav-container">
    <nav id="main-nav">
      <% 
        // 自动加载多语言菜单
        const menuLang = page.lang || config.i18n.default || config.language[0];
        const menuData = theme.menu && theme.menu[menuLang] ? theme.menu[menuLang] : theme.menu;
      %>
      <% for (let label in menuData) { %>
        <a class="main-nav-link" href="<%- url_for(menuData[label]) %>"><%= label %></a>
      <% } %>
    </nav>
  </div>

  <!--
  <div id="search-form-wrap">
    <%- search_form({button: '&#xF002;'}) %>
  </div>
  -->

  <div class="lang-switch">
    <a href="/zh-CN/" <%= page.lang === 'zh-CN' ? 'class="active"' : '' %>>中文</a> | 
    <a href="/en/" <%= page.lang === 'en' ? 'class="active"' : '' %>>English</a>
  </div>

  <h1 class="blog-title"><%= config.title[page.lang] || config.title %></h1>
  <p class="lead blog-description">
    <% if (config.subtitle) { %>
      <%= config.subtitle[page.lang] || config.subtitle %>
    <% } %>
  </p>
</div>
